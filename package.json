{
  "name": "telvault",
  "version": "1.0.0",
  "description": "Desktop versioning backed by private Telegram channels.",
  "main": "main.js",
  "scripts": {
    "dev:renderer": "cross-env NODE_ENV=development webpack serve --config webpack.config.js --mode development",
    "dev:electron": "wait-on http://localhost:3000 && cross-env NODE_ENV=development electron .",
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "build": "cross-env NODE_ENV=production webpack --config webpack.config.js --mode production",
    "start": "npm run build && electron .",
    "generate-icon": "node scripts/generate-icon.js",
    "rebuild": "electron-rebuild -f -w better-sqlite3 -w sharp",
    "dist": "npm run generate-icon && npm run build && electron-builder --win",
    "postinstall": "electron-builder install-app-deps"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "archiver": "^8.0.0",
    "better-sqlite3": "^12.10.0",
    "big-integer": "^1.6.52",
    "chokidar": "^5.0.0",
    "dotenv": "^17.4.2",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "telegram": "^2.26.22"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@electron/rebuild": "^4.0.4",
    "autoprefixer": "^10.5.0",
    "babel-loader": "^10.1.1",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.4",
    "electron": "^39.8.10",
    "electron-builder": "^26.15.3",
    "html-webpack-plugin": "^5.6.7",
    "postcss": "^8.5.15",
    "postcss-loader": "^8.2.1",
    "sharp": "^0.35.1",
    "style-loader": "^4.0.0",
    "tailwindcss": "^3.4.19",
    "wait-on": "^9.0.10",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3",
    "webpack-dev-server": "^5.2.5"
  },
  "build": {
    "appId": "app.telvault.desktop",
    "productName": "TelVault",
    "copyright": "Copyright © 2025 TelVault",
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "compression": "maximum",
    "electronLanguages": ["fr", "en-US"],
    "extraFiles": [],
    "extraResources": [],
    "files": [
      "main.js",
      "preload.js",
      "dist/**/*",
      "src/main/**/*",
      "assets/**/*",
      "package.json",
      "!src/renderer/**/*",
      "!scripts/**/*",
      "!**/*.map",
      "!**/test/**",
      "!**/tests/**",
      "!**/*.md"
    ],
    "npmRebuild": true,
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "TelVault",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "deleteAppDataOnUninstall": false
    }
  }
}
